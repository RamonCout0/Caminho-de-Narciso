[sub_resource type="CSharpScript" id="CSharpScript_vslsq"]
script/source = "using Godot;
using System;

public partial class LanternaLuz : PointLight2D
{
	public override void _Ready()
	{
		// No Godot 4 C#, usamos TextureRotation para radianos
		// Se der erro de novo, tente o código abaixo que é o \"plano B\"
		try 
		{
			this.TextureRotation = Mathf.DegToRad(90);
		}
		catch
		{
			// Plano B: Caso sua versão use um nome diferente
			Set(\"texture_rotation\", Mathf.DegToRad(90));
		}

		// Zera os offsets para a luz não \"fugir\" do mouse
		Offset = new Vector2(100, 0); // Ajuste esse 100 até a luz sair da lanterna
	}
}S
"

